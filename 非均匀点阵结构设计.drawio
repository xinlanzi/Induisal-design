        <mxCell id="5dDm-iPgjfxDwDZg73_k-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;胞元分类&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="20" x="371.09000000000003" y="340" as="geometry" />
        </mxCell>
        <mxCell id="5dDm-iPgjfxDwDZg73_k-16" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;" value="&lt;div&gt;&lt;font&gt;&lt;span style=&quot;font-family: FZSSK--GBK1-0; color: rgb(0, 0, 0);&quot;&gt;性能上：胞元本身&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSSK--GBK1-0;&quot;&gt;性能越优异&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSS-BJ;&quot;&gt;，&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSSK--GBK1-0;&quot;&gt;由它组成的非均匀点阵结构性能也越&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSSK--GBK1-0;&quot;&gt;好&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSS-BJ;&quot;&gt;，&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSSK--GBK1-0;&quot;&gt;而非均匀点阵结构的强度往往由最薄弱的胞元&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); font-family: FZSSK--GBK1-0; background-color: transparent;&quot;&gt;决定。&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="257.72" x="370" y="540" as="geometry" />
        </mxCell>
        <mxCell id="5dDm-iPgjfxDwDZg73_k-17" parent="1" style="text;whiteSpace=wrap;html=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;fontSize=12;fontColor=default;" value="&lt;div&gt;&lt;font&gt;&lt;span style=&quot;font-family: FZSSK--GBK1-0; color: rgb(0, 0, 0);&quot;&gt;由&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); font-family: FZSSK--GBK1-0; background-color: transparent;&quot;&gt;弯曲主导型胞元构成的弯曲主导型点阵结构通常有&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSSK--GBK1-0;&quot;&gt;着较低的强度和较高的柔性&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSS-BJ;&quot;&gt;，&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: rgb(0, 0, 0); font-family: FZSSK--GBK1-0;&quot;&gt;由拉伸主导型胞元构&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); font-family: FZSSK--GBK1-0; background-color: transparent;&quot;&gt;成的拉伸主导型点阵结构表现出较高的强度和刚&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); font-family: FZSSK--GBK1-0; background-color: transparent;&quot;&gt;度。&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="241.14" x="98.86" y="540" as="geometry" />
        </mxCell>
