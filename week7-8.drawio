        <mxCell id="E6MBim6C_pD2edmRkNQm-59" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div data-page-id=&quot;RYdrdCoJ0oAHa6xijk2clNybnVu&quot; data-lark-html-role=&quot;root&quot; data-docx-has-block-data=&quot;false&quot;&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-ToEyddm26oocGmxpI5UcM1F6nwc&quot;&gt;&lt;strong&gt;全因子设计&lt;/strong&gt;对所有可能的因子组合开展测试。该方法精度高，但所需的实验次数多&lt;/div&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-T1AWd9X1DoFZ22xFrs5cppecn9g&quot;&gt;&lt;strong&gt;田口法（Taguchi Method，正交阵列法）&lt;/strong&gt;通过选取特定的因子组合子集，以最少的实验次数，找到具备 “稳健性” 的参数-信息最大化尽量正交&lt;/div&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-Q6bNdhrpKoijRbxbYZQcUQ6onVg&quot;&gt;&lt;strong&gt;响应面法（&lt;/strong&gt;&lt;strong&gt;Response Surface Methodology&lt;/strong&gt;&lt;strong&gt;， &lt;/strong&gt;&lt;strong&gt;RSM&lt;/strong&gt;&lt;strong&gt;）&lt;/strong&gt;用于参数的精细化调优，以找到 “全局最优解”（例如，疲劳强度最大值对应的精确参数点）-不停缩小范围&lt;/div&gt;&lt;/div&gt;&lt;span data-lark-record-data=&quot;{&amp;quot;isCut&amp;quot;:false,&amp;quot;rootId&amp;quot;:&amp;quot;RYdrdCoJ0oAHa6xijk2clNybnVu&amp;quot;,&amp;quot;parentId&amp;quot;:&amp;quot;RYdrdCoJ0oAHa6xijk2clNybnVu&amp;quot;,&amp;quot;blockIds&amp;quot;:[382,383,384],&amp;quot;recordIds&amp;quot;:[&amp;quot;ToEyddm26oocGmxpI5UcM1F6nwc&amp;quot;,&amp;quot;T1AWd9X1DoFZ22xFrs5cppecn9g&amp;quot;,&amp;quot;Q6bNdhrpKoijRbxbYZQcUQ6onVg&amp;quot;],&amp;quot;recordMap&amp;quot;:{&amp;quot;ToEyddm26oocGmxpI5UcM1F6nwc&amp;quot;:{&amp;quot;id&amp;quot;:&amp;quot;ToEyddm26oocGmxpI5UcM1F6nwc&amp;quot;,&amp;quot;snapshot&amp;quot;:{&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;,&amp;quot;comments&amp;quot;:[],&amp;quot;children&amp;quot;:[],&amp;quot;align&amp;quot;:&amp;quot;left&amp;quot;,&amp;quot;parent_id&amp;quot;:&amp;quot;RYdrdCoJ0oAHa6xijk2clNybnVu&amp;quot;,&amp;quot;revisions&amp;quot;:[],&amp;quot;locked&amp;quot;:false,&amp;quot