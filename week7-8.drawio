ions&amp;quot;:[&amp;quot;editors&amp;quot;,&amp;quot;edit_time&amp;quot;],&amp;quot;deleted_editors&amp;quot;:null},&amp;quot;type&amp;quot;:&amp;quot;page&amp;quot;}}},&amp;quot;payloadMap&amp;quot;:{&amp;quot;DxrndR1u3o5z7XximDJcTjs1nac&amp;quot;:{&amp;quot;level&amp;quot;:1},&amp;quot;S337d9pRbobJ3hx1J8McLvalnbb&amp;quot;:{&amp;quot;level&amp;quot;:1},&amp;quot;VrFFdZprPoHZyYxXpaHcNmRYnVf&amp;quot;:{&amp;quot;level&amp;quot;:1},&amp;quot;NRniduxOjobT9xx44dzcAkXynXb&amp;quot;:{&amp;quot;level&amp;quot;:1},&amp;quot;lingoClipboardPayload&amp;quot;:{&amp;quot;spaceSubExtraInfo&amp;quot;:[{&amp;quot;spaceSubId&amp;quot;:&amp;quot;DxrndR1u3o5z7XximDJcTjs1nac&amp;quot;,&amp;quot;word&amp;quot;:&amp;quot;PVC&amp;quot;},{&amp;quot;spaceSubId&amp;quot;:&amp;quot;DxrndR1u3o5z7XximDJcTjs1nac&amp;quot;,&amp;quot;word&amp;quot;:&amp;quot;ABS&amp;quot;},{&amp;quot;spaceSubId&amp;quot;:&amp;quot;S337d9pRbobJ3hx1J8McLvalnbb&amp;quot;,&amp;quot;word&amp;quot;:&amp;quot;PP&amp;quot;},{&amp;quot;spaceSubId&amp;quot;:&amp;quot;VrFFdZprPoHZyYxXpaHcNmRYnVf&amp;quot;,&amp;quot;word&amp;quot;:&amp;quot;ABS&amp;quot;}],&amp;quot;spaceId&amp;quot;:&amp;quot;RYdrdCoJ0oAHa6xijk2clNybnVu&amp;quot;,&amp;quot;spaceType&amp;quot;:1}},&amp;quot;extra&amp;quot;:{&amp;quot;channel&amp;quot;:&amp;quot;saas&amp;quot;,&amp;quot;pasteRandomId&amp;quot;:&amp;quot;eac4b2cc-9e7e-47c6-8b83-df55839b5202&amp;quot;,&amp;quot;mention_page_title&amp;quot;:{},&amp;quot;external_mention_url&amp;quot;:{},&amp;quot;isEqualBlockSelection&amp;quot;:true},&amp;quot;isKeepQuoteContainer&amp;quot;:false,&amp;quot;selection&amp;quot;:[{&amp;quot;id&amp;quot;:386,&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;,&amp;quot;selection&amp;quot;:{&amp;quot;start&amp;quot;:0,&amp;quot;end&amp;quot;:62},&amp;quot;recordId&amp;quot;:&amp;quot;DxrndR1u3o5z7XximDJcTjs1nac&amp;quot;},{&amp;quot;id&amp;quot;:387,&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;,&amp;quot;selection&amp;quot;:{&amp;quot;start&amp;quot;:0,&amp;quot;end&amp;quot;:35},&amp;quot;recordId&amp;quot;:&amp;quot;S337d9pRbobJ3hx1J8McLvalnbb&amp;quot;},{&amp;quot;id&amp;quot;:388,&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;,&amp;quot;selection&amp;quot;:{&amp;quot;start&amp;quot;:0,&amp;quot;end&amp;quot;:28},&amp;quot;recordId&amp;quot;:&amp;quot;VrFFdZprPoHZyYxXpaHcNmRYnVf&amp;quot;},{&amp;quot;id&amp;quot;:389,&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;,&amp;quot;selection&amp;quot;:{&amp;quot;start&amp;quot;:0,&amp;quot;end&amp;quot;:14},&amp;quot;recordId&amp;quot;:&amp;quot;NRniduxOjobT9xx44dzcAkXynXb&amp;quot;}],&amp;quot;pasteFlag&amp;quot;:&amp;quot;2c8cf07b-eb3c-4675-9c79-a4f91197fdff&amp;quot;}&quot; data-lark-record-format=&quot;docx/record&quot; class=&quot;lark-record-clipboard&quot;&gt;&lt;/span&gt;" vertex="1">
          <mxGeometry height="100" width="456.37" x="61.309999999999945" y="2270" as="geometry" />
        </mxCell>
        <mxCell id="E6MBim6C_pD2edmRkNQm-41" parent="1" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;swimlaneFillColor=none;" value="缺陷说明" vertex="1">
          <mxGeometry height="855" width="590" x="-510" y="600" as="geometry" />
        </mxCell>
        <mxCell id="E6MBim6C_pD2edmRkNQm-40" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;div data-page-id=&quot;RYdrdCoJ0oAHa6xijk2clNybnVu&quot; data-lark-html-role=&quot;root&quot; data-docx-has-block-data=&quot;false&quot;&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-MZYUd4r4OofOnOxuzWhcHhLJnJg&quot;&gt;1. Splay（料花/水纹）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-HSrhdTiSKoM82ex1ht2ceD5JnLh&quot;&gt;&lt;strong&gt;混入挥发性气体：&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;塑料原料未充分干燥，残留水分高温汽化；料筒温度过高、螺杆剪切过强，导致塑料热分解产生小分子气体；注射速度/压力过大，熔体裹入空气；模具排气不良，气体无法顺利排出&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-Cn9Gdp9kBoVXH5xpIqzcyHhqn6g&quot;&gt;2. Flow lines（流痕/流线）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-U80EdTnWAoWdkLxBNp8cp2jJn3b&quot;&gt;&lt;strong&gt;冷却不均、流动不平稳：&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;料筒/模具温度过低，熔体冷却过快；注射速度/压力不足，熔体充模不平稳；浇口/流道尺寸过小，熔体流动阻力大、流速不稳定；塑料熔体本身流动性不足。&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-QUx7dT27moVd1Hxl52ncG9BWn4c&quot;&gt;3. Weld lines（熔接痕/熔合线）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-EcH7dchXnocohmxm8BJcUkcYnpG&quot;&gt;&lt;strong&gt;汇合时融合不良&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;：熔体/模具温度过低，料流前沿冷却快；注射压力/速度不足，熔体汇合时熔接压力不够；模具排气不良，汇合处 trapped 气体阻碍熔接；浇口位置设计不合理，导致料流汇合路径过长。&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-AfvzdOg6qowylxxS5XDceLwunfb&quot;&gt;5. Jetting（喷射流涎/蛇形流）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-HKuFdszBrobmF4xM9PlcDyovnwb&quot;&gt;&lt;strong&gt;熔体从浇口高速喷射进入型腔，未平稳铺展&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;：浇口尺寸过小，注射速度过快；浇口设计不合理，正对大型腔空间，无缓冲结构；熔体温度过低，粘度高，无法平稳铺展。&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-ERFNdmd03omrKixUcfwc88KAnbd&quot;&gt;6. Sink marks（缩痕/凹坑）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-EifOd4kXIorX4NxP46ZcxSvbnGh&quot;&gt;&lt;strong&gt;厚壁区域冷却收缩时，表层被内部熔体向内拉动凹陷&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;：制品壁厚设计不均，厚壁处收缩量大；保压压力/保压时间不足，无法补充熔体收缩的体积；料筒/熔体温度过高，冷却收缩量更大；浇口尺寸过小，保压补缩的压力无法有效传递到厚壁区域。&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-ABFgdRmZuoYFeLxLsgvcQRfGnUb&quot;&gt;7. Vacuum void（真空泡/气泡）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-Ee8wdRiJEonqCExoBhuc6ggTnuf&quot;&gt;&lt;strong&gt;厚壁区域内外冷却速度差异过大，内部形成负压真空孔洞&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;：制品壁厚过大，内外冷却速度悬殊；保压不足，无法补充收缩的体积；熔体温度过高，冷却收缩量更大；模具冷却不均匀，厚壁处冷却过慢。&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-WNPIdkfmWoOZGKxvFS6cMHMIns6&quot;&gt;8. Short shots（短射/缺料）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-UYWjdNdiwoF7ZexXzNbcxuzznCh&quot;&gt;&lt;strong&gt;还未完全填满型腔，就已提前冷却固化&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;：注射量/加料量不足；注射压力/速度过低，无法克服流动阻力充满型腔；熔体/模具温度过低，塑料流动性快速下降；流道/浇口尺寸过小，流动阻力过大；模具排气不良，型腔内空气无法排出，形成反压阻碍熔体填充。&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-ULBvdyPI4oN7UrxryeEcUzfOnkd&quot;&gt;9. Warping（翘曲变形）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-RmPodnNfjoBUn3x36GzcTJ2gnMe&quot;&gt;&lt;strong&gt;冷却过程中，各区域/各方向收缩率不均匀，内应力释放导致变形&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;：制品壁厚/结构设计不均，冷却收缩不一致；模具温度不均匀，型腔与型芯温差过大，制品两面收缩率不同；保压不均匀，浇口附近与远端收缩差异大；塑料分子取向不均匀，冷却后取向应力释放；顶出系统设计不合理，顶出力不均导致变形。&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-UfIddYTxqo2TEfxjDIBcAXCTnpg&quot;&gt;10. Burn marks（烧焦/焦痕）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-JUHbdMfz6orEnPxIzRQcxFXKnfe&quot;&gt;&lt;strong&gt;型腔内气体被绝热压缩，温度急剧升高，塑料碳化烧焦&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;：注射速度/压力过高，熔体充模速度太快，气体来不及排出；模具排气不良，排气槽位置/尺寸不足；料筒温度过高、螺杆转速过快，塑料在料筒内就已热分解、碳化；熔体在料筒内停留时间过长，过热分解。&lt;/span&gt;&lt;/div&gt;&lt;h4 style=&quot;text-align:left&quot; class=&quot;heading-4 ace-line old-record-id-Z9Zld7YB7oSB4nxUUKhcnw0Tnph&quot;&gt;11. Surface delamination（表面分层/起皮）&lt;/h4&gt;&lt;div style=&quot;text-align:left&quot; class=&quot;ace-line ace-line old-record-id-TcrhdsjdtoazhZx6lQ9cRsAQnQf&quot;&gt;&lt;strong&gt;表层与内部未能充分融合，出现层状分离&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;：塑料原料中混入了不同种类、不相容的塑料；原料中水分、杂质过多；熔体/模具温度过低，不同料流之间分子链无法充分缠结；塑料中添加剂过多，或回收料比例过高，相容性下降。&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;span data-lark-record-data=&quot;{&amp;quot;isCut&amp;quot;:false,&amp;quot;rootId&amp;quot;:&amp;quot;RYdrdCoJ0oAHa6xijk2clNybnVu&amp;quot;,&amp;quot;parentId&amp;quot;:&amp;quot;Xd20dn3V5oO5StxQXLecaoeRncd&amp;quot;,&amp;quot;blockIds&amp;quot;:[318,319,320,321,322,323,324,325,326,327,328,329,330,331,332,333,334,335,336,337,338,339,340,341,342,343,344,345,346,347],&amp;quot;recordIds&amp;quot;:[&amp;quot;MZYUd4r4OofOnOxuzWhcHhLJnJg&amp;quot;,&amp;quot;HSrhdTiSKoM82ex1ht2ceD5JnLh&amp;quot;,&amp;quot;EHJydgky7oerQVx3i5hcRvDcned&amp;quot;,&amp;quot;Cn9Gdp9kBoVXH5xpIqzcyHhqn6g&amp;quot;,&amp;quot;U80EdTnWAoWdkLxBNp8cp2jJn3b&amp;quot;,&amp;quot;FwdhdYN3GoyNqdxqt8Sc3tNgnLe&amp;quot;,&amp;quot;QUx7dT27moVd1Hxl52ncG9BWn4c&amp;quot;,&amp;quot;EcH7dchXnocohmxm8BJcUkcYnpG&amp;quot;,&amp;quot;UeA0dntFlosKRdx1GlScD65en8e&amp;quot;,&amp;quot;AfvzdOg6qowylxxS5XDceLwunfb&amp;quot;,&amp;quot;HKuFdszBrobmF4xM9PlcDyovnwb&amp;quot;,&amp;quot;KclwdJ07uoDewKxoSaxczl6Ynkf&amp;quot;,&amp;quot;ERFNdmd03omrKixUcfwc88KAnbd&amp;quot;,&amp;quot;EifOd4kXIorX4NxP46ZcxSvbnGh&amp;quot;,&amp;quot;FRjMdjrV5oMCTNxsvxkcc9iyncb&amp;quot;,&amp;quot;ABFgdRmZuoYFeLxLsgvcQRfGnUb&amp;quot;,&amp;quot;Ee8wdRiJEonqCExoBhuc6ggTnuf&amp;quot;,&amp;quot;FqkkdEMu4oueCUxUNz9cE0tsn6e&amp;quot;,&amp;quot;WNPIdkfmWoOZGKxvFS6cMHMIns6&amp;quot;,&amp;quot;UYWjdNdiwoF7ZexXzNbcxuzznCh&amp;quot;,&amp;quot;KcNodkfxPoKOIDxbJdsceynjnah&amp;quot;,&amp;quot;ULBvdyPI4oN7UrxryeEcUzfOnkd&amp;quot;,&amp;quot;RmPodnNfjoBUn3x36GzcTJ2gnMe&amp;quot;,&amp;quot;WBWXdjL5eoSfyixcSGvcWlOUnZd&amp;quot;,&amp;quot;UfIddYTxqo2TEfxjDIBcAXCTnpg&amp;quot;,&amp;quot;JUHbdMfz6orEnPxIzRQcxFXKnfe&amp;quot;,&amp;quot;F2agd5VHNobidTxuPKocRSsHnNd&amp;quot;,&amp;quot;Z9Zld7YB7oSB4nxUUKhcnw0Tnph&amp;quot;,&amp;quot;TcrhdsjdtoazhZx6lQ9cRsAQnQf&amp;quot;,&amp;quot;VzltdNwegoyx6gxT7RycoqjKnGh&amp;quot;],&amp;quot;recordMap&amp;quot;:{&amp;quot;MZYUd4r4OofOnOxuzWhcHhLJnJg&amp;quot;:{&amp;quot;id&amp;quot;:&amp;quot;MZYUd4r4OofOnOxuzWhcHhLJnJg&amp;quot;,&amp;quot;snapshot&amp;quot;:{&amp;quot;hidden&amp;quot;:false,&amp;quot;author&amp;quot;:&amp;quot;7429614893993967617&amp;quot;,&amp;quot;text&amp;quot;:{&amp;quot;initialAttributedTexts&amp;quot;:{&amp;quot;text&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;1. Splay（料花/水纹）&amp;quot;},&amp;quot;attribs&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;*0+f&amp;quot;}},&amp;quot;apool&amp;quot;:{&amp;quot;numToAttrib&amp;quot;:{&amp;quot;0&amp;quot;:[&amp;quot;author&amp;quot;,&amp;quot;7429614893993967617&amp;quot;]},&amp;quot;nextNum&amp;quot;:1}},&amp;quot;folded&amp;quot;:false,&amp;quot;type&amp;quot;:&amp;quot;heading4&amp;quot;,&amp;quot;comments&amp;quot;:[],&amp;quot;revisions&amp;quot;:[],&amp;quot;locked&amp;quot;:false,&amp;quot;children&amp;quot;:[],&amp;quot;align&amp;quot;:&amp;quot;left&amp;quot;,&amp;quot;parent_id&amp;quot;:&amp;quot;Xd20dn3V5oO5StxQXLecaoeRncd&amp;quot;}},&amp;quot;HSrhdTiSKoM82ex1ht2ceD5JnLh&amp;quot;:{&amp;quot;id&amp;quot;:&amp;quot;HSrhdTiSKoM82ex1ht2ceD5JnLh&amp;quot;,&amp;quot;snapshot&amp;quot;:{&amp;quot;folded&amp;quot;:false,&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;,&amp;quot;parent_id&amp;quot;:&amp;quot;Xd20dn3V5oO5StxQXLecaoeRncd&amp;quot;,&amp;quot;revisions&amp;quot;:[],&amp;quot;locked&amp;quot;:false,&amp;quot;text&amp;quot;:{&amp;quot;apool&amp;quot;:{&amp;quot;nextNum&amp;quot;:2,&amp;quot;numToAttrib&amp;quot;:{&amp;quot;0&amp;quot;:[&amp;quot;author&amp;quot;,&amp;quot;7429614893993967617&amp;quot;],&amp;quot;1&amp;quot;:[&amp;quot;bold&amp;quot;,&amp;quot;true&amp;quot;]}},&amp;quot;initialAttributedTexts&amp;quot;:{&amp;quot;text&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;核心成因是熔融塑料中混入挥发性气体，注射充模时，气体被高压熔体剪切破裂，最终在制品表面形成银白色喷溅状、条纹状痕迹。&amp;quot;},&amp;quot;attribs&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;*0+5*0*1+c*0+15&amp;quot;}}},&amp;quot;align&amp;quot;:&amp;quot;left&amp;quot;,&amp;quot;comments&amp;quot;:[],&amp;quot;hidden&amp;quot;:false,&amp;quot;author&amp;quot;:&amp;quot;7429614893993967617&amp;quot;,&amp;quot;children&amp;quot;:[]}},&amp;quot;EHJydgky7oerQVx3i5hcRvDcned&amp;quot;:{&amp;quot;id&amp;quot;:&amp;quot;EHJydgky7oerQVx3i5hcRvDcned&amp;quot;,&amp;quot;snapshot&amp;quot;:{&amp;quot;revisions&amp;quot;:[],&amp;quot;author&amp;quot;:&amp;quot;7429614893993967617&amp;quot;,&amp;quot;text&amp;quot;:{&amp;quot;apool&amp;quot;:{&amp;quot;nextNum&amp;quot;:1,&amp;quot;numToAttrib&amp;quot;:{&amp;quot;0&amp;quot;:[&amp;quot;author&amp;quot;,&amp;quot;7429614893993967617&amp;quot;]}},&amp;quot;initialAttributedTexts&amp;quot;:{&amp;quot;attribs&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;*0+2e&amp;quot;},&amp;quot;text&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;关键诱因：塑料原料未充分干燥，残留水分高温汽化；料筒温度过高、螺杆剪切过强，导致塑料热分解产生小分子气体；注射速度/压力过大，熔体裹入空气；模具排气不良，气体无法顺利排出。&amp;quot;}}},&amp;quot;folded&amp;quot;:false,&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;,&amp;quot;comments&amp;quot;:[],&amp;quot;hidden&amp;quot;:false,&amp;quot;children&amp;quot;:[],&amp;quot;align&amp;quot;:&amp;quot;left&amp;quot;,&amp;quot;parent_id&amp;quot;:&amp;quot;Xd20dn3V5oO5StxQXLecaoeRncd&amp;quot;,&amp;quot;locked&amp;quot;:false}},&amp;quot;Cn9Gdp9kBoVXH5xpIqzcyHhqn6g&amp;quot;:{&amp;quot;id&amp;quot;:&amp;quot;Cn9Gdp9kBoVXH5xpIqzcyHhqn6g&amp;quot;,&amp;quot;snapshot&amp;quot;:{&amp;quot;parent_id&amp;quot;:&amp;quot;Xd20dn3V5oO5StxQXLecaoeRncd&amp;quot;,&amp;quot;revisions&amp;quot;:[],&amp;quot;text&amp;quot;:{&amp;quot;initialAttributedTexts&amp;quot;:{&amp;quot;attribs&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;*0+k&amp;quot;},&amp;quot;text&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;2. Flow lines（流痕/流线）&amp;quot;}},&amp;quot;apool&amp;quot;:{&amp;quot;nextNum&amp;quot;:1,&amp;quot;numToAttrib&amp;quot;:{&amp;quot;0&amp;quot;:[&amp;quot;author&amp;quot;,&amp;quot;7429614893993967617&amp;quot;]}}},&amp;quot;align&amp;quot;:&amp;quot;left&amp;quot;,&amp;quot;folded&amp;quot;:false,&amp;quot;type&amp;quot;:&amp;quot;heading4&amp;quot;,&amp;quot;comments&amp;quot;:[],&amp;quot;locked&amp;quot;:false,&amp;quot;hidden&amp;quot;:false,&amp;quot;author&amp;quot;:&amp;quot;7429614893993967617&amp;quot;,&amp;quot;children&amp;quot;:[]}},&amp;quot;U80EdTnWAoWdkLxBNp8cp2jJn3b&amp;quot;:{&amp;quot;id&amp;quot;:&amp;quot;U80EdTnWAoWdkLxBNp8cp2jJn3b&amp;quot;,&amp;quot;snapshot&amp;quot;:{&amp;quot;locked&amp;quot;:false,&amp;quot;hidden&amp;quot;:false,&amp;quot;author&amp;quot;:&amp;quot;7429614893993967617&amp;quot;,&amp;quot;children&amp;quot;:[],&amp;quot;text&amp;quot;:{&amp;quot;apool&amp;quot;:{&amp;quot;nextNum&amp;quot;:2,&amp;quot;numToAttrib&amp;quot;:{&amp;quot;0&amp;quot;:[&amp;quot;author&amp;quot;,&amp;quot;7429614893993967617&amp;quot;],&amp;quot;1&amp;quot;:[&amp;quot;bold&amp;quot;,&amp;quot;true&amp;quot;]}},&amp;quot;initialAttributedTexts&amp;quot;:{&amp;quot;text&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;核心成因是熔体充模过程中冷却不均、流动不平稳，先接触冷模具壁的熔体快速冷却，后续高温熔体推动冷却料流向前，在制品表面形成沿流动方向的波纹/条纹痕迹。&amp;quot;},&amp;quot;attribs&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;*0+5*0*1+h*0+1g&amp;quot;}}},&amp;quot;folded&amp;quot;:false,&amp;quot;parent_id&amp;quot;:&amp;quot;Xd20dn3V5oO5StxQXLecaoeRncd&amp;quot;,&amp;quot;comments&amp;quot;:[],&amp;quot;revisions&amp;quot;:[],&amp;quot;align&amp;quot;:&amp;quot;left&amp;quot;,&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;}},&amp;quot;FwdhdYN3GoyNqdxqt8Sc3tNgnLe&amp;quot;:{&amp;quot;id&amp;quot;:&amp;quot;FwdhdYN3GoyNqdxqt8Sc3tNgnLe&amp;quot;,&amp;quot;snapshot&amp;quot;:{&amp;quot;type&amp;quot;:&amp;quot;text&amp;quot;,&amp;quot;children&amp;quot;:[],&amp;quot;text&amp;quot;:{&amp;quot;apool&amp;quot;:{&amp;quot;nextNum&amp;quot;:1,&amp;quot;numToAttrib&amp;quot;:{&amp;quot;0&amp;quot;:[&amp;quot;author&amp;quot;,&amp;quot;7429614893993967617&amp;quot;]}},&amp;quot;initialAttributedTexts&amp;quot;:{&amp;quot;attribs&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;*0+24&amp;quot;},&amp;quot;text&amp;quot;:{&amp;quot;0&amp;quot;:&amp;quot;关键诱因：料筒/模具温度过低，熔体冷却过快；注射速度/压力不足，熔体充模不平稳；浇口/流道尺寸过小，熔体流动阻力大、流速不稳定；塑料熔体本身流动性不足。&amp;quot;}}},&amp;quot;align&amp;quot;:&amp;quot;left&amp;quot;,&amp;quot;folded&amp;quot;:false,&amp;quot;parent_id&amp;quot;:&amp;quot;Xd20dn3V5oO5StxQXLecaoeRncd&amp;quot;,&amp;quot;comments&amp;quot;:[],&amp;quot;revisions&amp;quot;:[],&amp;quot;locked&amp;quot;:false,&amp;quot;hidden&am